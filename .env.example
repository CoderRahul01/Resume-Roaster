# ─── AI Provider ──────────────────────────────────────────────────────────────
# Toggle in lib/config.ts: AI_PROVIDER = "nvidia" | "claude"

# NVIDIA NIM free API key (build.nvidia.com → sign in → Get API Key)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude (only needed when AI_PROVIDER = "claude")
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Supabase dashboard → Settings → Database → URI (replace [YOUR-PASSWORD])
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.wfggrantinqtejmegwma.supabase.co:5432/postgres

# One-time setup: push schema to Supabase (run locally once):
#   DATABASE_URL=postgresql://... npx prisma db push

# ─── Google OAuth (NextAuth v5) ────────────────────────────────────────────────
# Source: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Add these Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google   ← local dev
#   https://YOUR_RAILWAY_DOMAIN/api/auth/callback/google  ← production
AUTH_SECRET=your-random-secret-run-openssl-rand-base64-32
AUTH_GOOGLE_ID=xxxxxxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Razorpay (payments) ──────────────────────────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys
# Local dev: rzp_test_...   Production: rzp_live_...
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Redis (optional — rate limiting) ─────────────────────────────────────────
# Railway Redis plugin sets REDIS_URL automatically. Omit locally to disable rate limiting.
# REDIS_URL=redis://default:password@host:6379

# ─── Coupons (optional) ───────────────────────────────────────────────────────
# Format: "CODE:percent,CODE2:percent"  — 100 = fully free
# COUPON_CODES=LAUNCH100:100,HALF50:50
